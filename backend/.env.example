# ── LlamaParse ───────────────────────────────────────────────────────────
LLAMAPARSE_API_KEY=llx-...

# ── HuggingFace Inference API ─────────────────────────────────────────────
HF_API_KEY=hf_...
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# ── Qdrant Cloud ──────────────────────────────────────────────────────────
QDRANT_URL=https://xxxx.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=lexguard_contracts

# ── NVIDIA NIM (OpenAI-compatible) ────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_TIMEOUT=300
NVIDIA_MAX_RETRIES=10

# ── LangSmith ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=lexguard
LANGSMITH_TRACING=true

# ── Neon DB (PostgreSQL) ──────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb

# ── RAG Pipeline ──────────────────────────────────────────────────────────
MAX_RAG_RETRIES=3
MAX_HISTORY_MESSAGES=10
RETRIEVAL_TOP_K=10
QUALITY_THRESHOLD=0.2

# ── App ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=50
