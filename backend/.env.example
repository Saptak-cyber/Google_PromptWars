# ── LlamaParse ───────────────────────────────────────────────────────────
LLAMAPARSE_API_KEY=llx-...

# ── HuggingFace Inference API ─────────────────────────────────────────────
HF_API_KEY=hf_...
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768

# ── Qdrant Cloud ──────────────────────────────────────────────────────────
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=lexguard_contracts

# ── NVIDIA NIM (OpenAI-compatible) ────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── LangSmith ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=lexguard
LANGSMITH_TRACING=true

# ── Neon DB (PostgreSQL) ──────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/lexguard

# ── RAG Pipeline ──────────────────────────────────────────────────────────
MAX_RAG_RETRIES=3
MAX_HISTORY_MESSAGES=10
RETRIEVAL_TOP_K=8
QUALITY_THRESHOLD=0.65

# ── App ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=50
